{
  "name": "github-contribution-chart",
  "version": "1.0.0",
  "description": "Headless GitHub contribution calendar: data fetcher + zero-dep React chart component",
  "author": "Om Achrekar",
  "license": "MIT",
  "keywords": [
    "github",
    "contributions",
    "calendar",
    "heatmap",
    "react"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=17.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19",
    "tsup": "^8.0.0",
    "typescript": "^5"
  }
}
